locals {
  f5xc_sms_name = format("%s-site-%s", var.prefix, random_id.id.hex)
  azs = [
    for each_az in var.azs_short : format("%s%s", var.region, each_az)
  ]
}

variable "f5xc_ami" {
  description = "value of ami to use for XC instance - get this from XC UI (click site ... and select 'copy image name')"
  default     = "*f5xc-ce-crt-20251002*"
}

variable "f5xc_sms_node_count" {
  description = "Number of nodes (sites) to deploy"
  default     = 3
}

variable "f5xc_sms_description" {
  type    = string
  default = "Arch Azure smsv2 site created with Terraform"
}

variable "region" {
  description = "AWS region name"
  default     = "eu-west-2"
}

variable "azs_short" {
  description = "Assumes three AZs within region.  Locals below will format the full AZ names based on Region"
  default     = ["a", "b", "c"]
}

variable "cidr" {
  description = "cidr used for AWS VPC"
  default     = "10.0.0.0/16"
}

variable "prefix" {
  description = "prefix used for naming objects created in AWS"
  default     = "my-tf-aws-smsv2"
}

variable "uk_se_name" {
  description = "UK SE name tag"
  default     = "<name>"
}

variable "f5xc_namespace" {
  type        = string
  description = "F5 XC app namespace where the object will be created. This cannot be system or shared ns."
  default     = "my-namespace"
}

variable "aks_k8s_namespace" {
  type        = string
  description = "External k8s namespace where objects (LB / k8s svc) will be created by XC, if no namespace is included."
  default     = "azure-aks"
}

variable "eks_k8s_namespace" {
  type        = string
  description = "External k8s namespace where objects (LB / k8s svc) will be created by XC, if no namespace is included."
  default     = "aws-eks"
}

variable "base" {
  default = "eks"
}

variable "f5xc_tenant" {
  type        = string
  description = "F5 XC tenant name"
  default     = "my-tenant-abcxyz"
}

variable "f5xc_api_url" {
  type        = string
  description = "F5 XC tenant api url"
  default     = "https://my-tenant.console.ves.volterra.io/api"
}

variable "f5xc_api_p12_file" {
  type        = string
  description = "F5 XC tenant api key"
  default     = "../../../../creds/my-tenant.console.ves.volterra.io.api-creds.p12"
}

variable "sa_name" {
  default = "f5xc"
}

variable "linux_server_count" {
  type        = number
  description = "Number of Linux NGINX servers to deploy"
  default     = 2

  validation {
    condition     = var.linux_server_count >= 1 && floor(var.linux_server_count) == var.linux_server_count
    error_message = "linux_server_count must be a whole number of 1 or greater."
  }
}

variable "tailscale_auth_key" {
  type        = string
  description = "Optional Tailscale auth key. When set, Linux VMs will join the tailnet."
  default     = ""
  sensitive   = true
}

variable "tailscale_tag" {
  type        = string
  description = "Tailscale ACL tag advertised by the subnet router."
  default     = "tsr-aws"
}

variable "tailscale_advertise_routes" {
  type        = list(string)
  description = "Routes advertised by the dedicated Tailscale subnet-router VM."
  default     = ["10.99.0.0/16"]
}

variable "f5xc_ce_ipsec_peer_ip" {
  type        = string
  description = "Optional override for the F5 XC CE IPsec peer IP. Leave empty to use the CE outside ENI IP."
  default     = ""
}

variable "f5xc_ce_ipsec_psk" {
  type        = string
  description = "Optional PSK override for IPsec from the Tailscale subnet-router to the F5 XC CE. Leave empty to generate one."
  default     = ""
  sensitive   = true
}

variable "f5xc_ce_ipsec_remote_routes" {
  type        = list(string)
  description = "Remote traffic selectors protected by the IPsec tunnel to F5 XC CE."
  default     = ["10.99.0.0/16"]
}

variable "f5xc_ce_ipsec_interface_name" {
  type        = string
  description = "Linux XFRM interface name for the route-based IPsec tunnel to F5 XC CE."
  default     = "ipsec0"
}

variable "f5xc_ce_ipsec_interface_id" {
  type        = number
  description = "XFRM interface ID used to bind the strongSwan child SA to the route-based IPsec interface."
  default     = 42
}

variable "f5xc_ce_ipsec_local_tunnel_ip" {
  type        = string
  description = "SR-side tunnel IP configured on the route-based IPsec interface."
  default     = "172.16.1.2/24"
}

variable "f5xc_ce_ipsec_remote_tunnel_ip" {
  type        = string
  description = "F5 XC CE-side tunnel IP reachable across the route-based IPsec interface."
  default     = "172.16.1.1"
}

variable "f5xc_ce_ipsec_ike_proposals" {
  type        = string
  description = "strongSwan IKE proposal for the F5 XC CE IPsec tunnel."
  default     = "aes256-sha256-modp2048"
}

variable "f5xc_ce_ipsec_esp_proposals" {
  type        = string
  description = "strongSwan ESP proposal for the F5 XC CE IPsec tunnel."
  default     = "aes256-sha256-modp2048"
}
