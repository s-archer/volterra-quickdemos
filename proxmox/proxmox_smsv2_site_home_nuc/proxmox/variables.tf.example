# Copy this file to variables.tf for local use.

variable "pm_target_node" {
  default = "proxmox-node"
}

variable "iso_storage_pool" {
  type    = string
  default = "local"
}

variable "pm_storage_pool" {
  type    = string
  default = "local-lvm"
}

variable "ssh_public_key" {
  default = "ssh-rsa AAAAexample example@example"
}

variable "pm_clone" {
  default = "ubuntu-template"
}

variable "pm_pool" {
  type    = string
  default = ""
}

variable "latitude" {
  type    = number
  default = 51
}

variable "longitude" {
  type    = number
  default = 0
}

variable "http_proxy" {
  type    = string
  default = ""
}

variable "volterra_certified_hw" {
  type    = string
  default = "kvm-voltmesh"
}

variable "f5xc_vsite_label" {
  type    = string
  default = "virtual-site"
}

variable "f5xc_api_url" {
  type    = string
  default = "https://example.console.ves.volterra.io/api"
}

variable "f5xc_api_token" {
  type      = string
  sensitive = true
  default   = ""
}

variable "f5xc_tenant" {
  type    = string
  default = "example"
}

variable "f5xc_sms_name" {
  type    = string
  default = "example-proxmox-smsv2"
}

variable "master_cpus" {
  type    = number
  default = 4
}

variable "secure_mesh_cpus" {
  type    = number
  default = 4
}

variable "secure_mesh_memory" {
  type    = number
  default = 8192
}

variable "outside_network" {
  type    = string
  default = "vmbr0"
}

variable "outside_network_vlan" {
  type    = number
  default = 0
}

variable "outside_macaddr" {
  type    = string
  default = ""
}

variable "inside_network" {
  type    = string
  default = ""
}

variable "inside_network_vlan" {
  type    = number
  default = -1
}

variable "inside_ipv4_prefix" {
  type    = string
  default = "192.168.2.0/24"
}

variable "inside_macaddr" {
  type    = string
  default = ""
}

variable "kubevirt" {
  type    = bool
  default = false
}

variable "f5xc_registration_wait_time" {
  type    = number
  default = 60
}

variable "f5xc_registration_retry" {
  type    = number
  default = 20
}

variable "f5xc_tunnel_type" {
  type    = string
  default = "SITE_TO_SITE_TUNNEL_IPSEC_OR_SSL"
}

variable "operating_system_version" {
  type    = string
  default = ""
}

variable "volterra_software_version" {
  type    = string
  default = ""
}

variable "bgp_enable" {
  type    = bool
  default = false
}
