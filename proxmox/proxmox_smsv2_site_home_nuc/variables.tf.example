# Copy this file to variables.tf for local use.

locals {
  f5xc_sms_name = format("%s-site-%s", var.prefix, random_id.id.hex)
}

variable "prefix" {
  default = "example-proxmox-smsv2"
}

variable "f5xc_api_p12_file" {
  default = "../../../../creds/example.console.ves.volterra.io.api-creds.p12"
}

variable "f5xc_api_url" {
  default = "https://example.console.ves.volterra.io/api"
}

variable "f5xc_api_token" {
  sensitive = true
  default   = ""
}

variable "f5xc_tenant" {
  default = "example"
}

variable "pm_api_url" {
  default = "https://proxmox.example.com:8006/api2/json"
}

variable "pm_api_token_id" {
  default = "terraform@example!token"
}

variable "pm_api_token_secret" {
  sensitive = true
  default   = ""
}

variable "pm_target_nodes" {
  default = ["proxmox-node"]
}

variable "pm_clone" {
  default = "ubuntu-template"
}

variable "pm_pool" {
  type    = string
  default = ""
}

variable "iso_storage_pool" {
  type    = string
  default = "local"
}

variable "pm_storage_pool" {
  type    = string
  default = "local-lvm"
}

variable "ssh_public_key" {
  default = "ssh-rsa AAAAexample example@example"
}

variable "outside_macaddr" {
  default = ""
}

variable "inside_macaddr" {
  default = ""
}

variable "bgp_enable" {
  type    = bool
  default = false
}
